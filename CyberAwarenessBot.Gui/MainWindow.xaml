<Window x:Class="CyberAwarenessBot.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberAwareness Bot" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E90FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Resources>
    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Logo -->
        <TextBlock x:Name="txtAsciiLogo" 
                   FontFamily="Consolas" FontSize="14" 
                   Foreground="#00FFFF" HorizontalAlignment="Center"
                   TextAlignment="Center" Margin="0,10"/>

        <!-- Chat Display Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <TextBox x:Name="txtChatDisplay" 
                     IsReadOnly="True" Background="#16213E" Foreground="#E0E0E0"
                     BorderThickness="0" TextWrapping="Wrap" 
                     FontFamily="Segoe UI" FontSize="13"
                     VerticalScrollBarVisibility="Disabled"/>
        </ScrollViewer>

        <!-- Input Row -->
        <Border Grid.Row="2" Background="#0F3460" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtUserInput" 
                         Background="#16213E" Foreground="White" 
                         BorderBrush="#1A1A2E" FontSize="14"
                         KeyDown="txtUserInput_KeyDown"/>
                <Button Grid.Column="1" Content="Send" Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>